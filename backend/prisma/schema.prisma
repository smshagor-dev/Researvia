  @@index([isActive, expiresAt])
  @@map("coupons")
}

model CouponRedemption {
  id         String   @id @default(uuid()) @db.Char(36)
  couponId   String   @map("coupon_id") @db.Char(36)
  userId     String   @map("user_id") @db.Char(36)
  code       String   @db.VarChar(100)
  subscriptionId String? @map("subscription_id") @db.Char(36)
  stripeInvoiceId String? @map("stripe_invoice_id") @db.VarChar(100)
  stripeCheckoutSessionId String? @map("stripe_checkout_session_id") @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at")

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([couponId, userId])
  @@index([couponId, createdAt])
  @@index([userId, createdAt])
  @@index([subscriptionId])
  @@index([stripeInvoiceId])
  @@map("coupon_redemptions")
}

model Team {
  id        String   @id @default(uuid()) @db.Char(36)
  ownerId   String   @map("owner_id") @db.Char(36)
  name      String   @db.VarChar(255)
  planId    String   @map("plan_id") @db.Char(36)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner User @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  plan  SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  members TeamMember[]

  @@index([ownerId])
  @@index([planId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid()) @db.Char(36)
  teamId    String   @map("team_id") @db.Char(36)
  userId    String   @map("user_id") @db.Char(36)
  role      TeamRole
  createdAt DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model Notification {
  id        String              @id @default(uuid()) @db.Char(36)
  userId    String              @map("user_id") @db.Char(36)
  type      String              @db.VarChar(100)
  title     String              @db.VarChar(300)
  body      String?             @db.Text
  actionUrl String?             @map("action_url") @db.VarChar(500)
  data      Json?
  channel   NotificationChannel @default(in_app)
  isRead    Boolean             @default(false) @map("is_read")
  readAt    DateTime?           @map("read_at")
  createdAt DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model ActivityLog {
  id         BigInt   @id @default(autoincrement())
  userId     String?  @map("user_id") @db.Char(36)
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Char(36)
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("activity_logs")
}

model AuditLog {
  id         BigInt    @id @default(autoincrement())
  actorId    String?   @map("actor_id") @db.Char(36)
  actorType  ActorType @map("actor_type")
  action     String    @db.VarChar(100)
  entityType String?   @map("entity_type") @db.VarChar(50)
  entityId   String?   @map("entity_id") @db.Char(36)
  oldValues  Json?     @map("old_values")
  newValues  Json?     @map("new_values")
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ActiveSession {
  id                 String   @id @default(uuid()) @db.Char(36)
  userId             String   @map("user_id") @db.Char(36)
  refreshTokenHash   String?  @map("refresh_token_hash") @db.VarChar(255)
  ipAddress          String?  @map("ip_address") @db.VarChar(45)
  userAgent          String?  @map("user_agent") @db.VarChar(500)
  lastActivityAt     DateTime @default(now()) @map("last_activity_at")
  expiresAt          DateTime @map("expires_at")
  revokedAt          DateTime? @map("revoked_at")
  revokeReason       String?  @map("revoke_reason") @db.VarChar(255)
  rotationCounter    Int      @default(0) @map("rotation_counter")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@index([lastActivityAt])
  @@map("active_sessions")
}

model IpReputation {
  id                 String   @id @default(uuid()) @db.Char(36)
  ipAddress          String   @unique @map("ip_address") @db.VarChar(45)
  reputationScore    Int      @default(0) @map("reputation_score")
  failedAttempts     Int      @default(0) @map("failed_attempts")
  successfulAttempts Int      @default(0) @map("successful_attempts")
  suspiciousEvents   Int      @default(0) @map("suspicious_events")
  blockedUntil       DateTime? @map("blocked_until")
  lastUserAgent      String?  @map("last_user_agent") @db.VarChar(500)
  lastSeenAt         DateTime @default(now()) @map("last_seen_at")
  metadataJson       Json?    @map("metadata_json")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([blockedUntil])
  @@index([reputationScore])
  @@map("ip_reputations")
}

model BackupJob {
  id          String       @id @default(uuid()) @db.Char(36)
  type        BackupType
  status      BackupStatus @default(pending)
  startedAt   DateTime     @default(now()) @map("started_at")
  completedAt DateTime?    @map("completed_at")
  location    String?      @db.VarChar(1000)
  size        BigInt?      @db.BigInt
  checksum    String?      @db.VarChar(255)
  metadataJson Json?       @map("metadata_json")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([type, startedAt])
  @@index([status, startedAt])
  @@map("backup_jobs")
}

model VerificationLog {
  id                BigInt             @id @default(autoincrement())
  professorEmailId  String             @map("professor_email_id") @db.Char(36)
  source            VerificationSource
  sourceUrl         String?            @map("source_url") @db.VarChar(1000)
  result            String             @db.VarChar(50)
  rawResponse       Json?              @map("raw_response")
  domainMatched     Boolean            @default(false) @map("domain_matched")
  mxCheckResult     Boolean?           @map("mx_check_result")
  smtpCheckResult   Boolean?           @map("smtp_check_result")
  verifiedByAdmin   String?            @map("verified_by_admin") @db.Char(36)
  notes             String?            @db.Text
  createdAt         DateTime           @default(now()) @map("created_at")

  professorEmail ProfessorEmail @relation(fields: [professorEmailId], references: [id], onDelete: Cascade)

  @@index([professorEmailId])
  @@map("verification_logs")
}

model ApiUsageLog {
  id          BigInt    @id @default(autoincrement())
  source      ApiSource
  endpoint    String    @db.VarChar(500)
  method      String    @db.VarChar(10)
  statusCode  Int?      @map("status_code")
  responseMs  Int?      @map("response_ms")
  error       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([source, createdAt])
  @@map("api_usage_logs")
}

model Import {
  id            String       @id @default(uuid()) @db.Char(36)
  userId        String?      @map("user_id") @db.Char(36)
  type          ImportType
  fileKey       String?      @map("file_key") @db.VarChar(1000)
  source        ImportSource
  status        ImportStatus @default(pending)
  totalRows     Int          @default(0) @map("total_rows")
  processedRows Int          @default(0) @map("processed_rows")
  successRows   Int          @default(0) @map("success_rows")
  errorRows     Int          @default(0) @map("error_rows")
  errorLog      Json?        @map("error_log")
  startedAt     DateTime?    @map("started_at")
  completedAt   DateTime?    @map("completed_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("imports")
}
