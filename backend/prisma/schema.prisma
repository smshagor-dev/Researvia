// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid()) @db.Char(36)
  email                String    @unique @db.VarChar(255)
  passwordHash         String?   @map("password_hash") @db.VarChar(255)
  fullName             String    @map("full_name") @db.VarChar(255)
  avatarUrl            String?   @map("avatar_url") @db.VarChar(500)
  role                 UserRole  @default(user)
  status               UserStatus @default(active)
  emailVerifiedAt      DateTime? @map("email_verified_at")
  twoFactorSecret      String?   @map("two_factor_secret") @db.VarChar(255)
  twoFactorEnabled     Boolean   @default(false) @map("two_factor_enabled")
  twoFactorBackupCodes Json?     @map("two_factor_backup_codes")
  lastLoginAt          DateTime? @map("last_login_at")
  lastLoginIp          String?   @map("last_login_ip") @db.VarChar(45)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  profile           UserProfile?
  studentProfile    StudentProfile?
  oauthAccounts     OauthAccount[]
  smtpAccounts      SmtpAccount[]
  emailAccounts     EmailAccount[]
  subscriptions     Subscription[]
  credits           Credits?
  creditTransactions CreditTransaction[]
  emailThreads      EmailThread[]
  emailMessages     EmailMessage[]
  favorites         Favorite[]
  savedScholarships SavedScholarship[]
  notifications     Notification[]
  activityLogs      ActivityLog[]
  imports           Import[]

  @@index([status, deletedAt])
  @@map("users")
}

model UserProfile {
  id                String       @id @default(uuid()) @db.Char(36)
  userId            String       @unique @map("user_id") @db.Char(36)
  bio               String?      @db.Text
  currentDegree     DegreeLevel? @map("current_degree")
  gpa               Decimal?     @db.Decimal(4, 2)
  ieltsScore        Decimal?     @map("ielts_score") @db.Decimal(3, 1)
  toeflScore        Int?         @map("toefl_score")
  greVerbal         Int?         @map("gre_verbal")
  greQuant          Int?         @map("gre_quant")
  greAwa            Decimal?     @map("gre_awa") @db.Decimal(3, 1)
  researchInterests Json?        @map("research_interests")
  targetDegree      TargetDegree? @map("target_degree")
  targetCountries   Json?        @map("target_countries")
  targetStartTerm   String?      @map("target_start_term") @db.VarChar(20)
  linkedinUrl       String?      @map("linkedin_url") @db.VarChar(500)
  githubUrl         String?      @map("github_url") @db.VarChar(500)
  googleScholarUrl  String?      @map("google_scholar_url") @db.VarChar(500)
  orcidId           String?      @map("orcid_id") @db.VarChar(50)
  cvFileKey         String?      @map("cv_file_key") @db.VarChar(500)
  sopFileKey        String?      @map("sop_file_key") @db.VarChar(500)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model StudentProfile {
  id                    String                   @id @default(uuid()) @db.Char(36)
  userId                String                   @unique @map("user_id") @db.Char(36)
  fullName              String                   @map("full_name") @db.VarChar(255)
  preferredName         String?                  @map("preferred_name") @db.VarChar(255)
  profilePhotoUrl       String?                  @map("profile_photo_url") @db.VarChar(500)
  gender                String?                  @db.VarChar(50)
  dateOfBirth           DateTime?                @map("date_of_birth") @db.Date
  nationality           String                   @db.VarChar(100)
  currentCountry        String                   @map("current_country") @db.VarChar(100)
  city                  String?                  @db.VarChar(120)
  phone                 String?                  @db.VarChar(50)
  whatsapp              String?                  @db.VarChar(50)
  linkedin              String?                  @db.VarChar(500)
  github                String?                  @db.VarChar(500)
  website               String?                  @db.VarChar(500)
  shortBio              String?                  @map("short_bio") @db.Text
  careerGoal            String?                  @map("career_goal") @db.Text
  whyInterestedInResearch String?                @map("why_interested_in_research") @db.Text
  profileCompleteness   Int                      @default(0) @map("profile_completeness")
  onboardingCompleted   Boolean                  @default(false) @map("onboarding_completed")
  onboardingStep        Int                      @default(1) @map("onboarding_step")
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")

  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  education         StudentEducation?
  researchInterest  StudentResearchInterest?
  skills            StudentSkill[]
  experiences       StudentExperience[]
  projects          StudentProject[]
  publications      StudentPublication[]
  documents         StudentDocument[]
  testScores        StudentTestScore[]
  preference        StudentPreference?

  @@index([nationality])
  @@index([currentCountry])
  @@index([onboardingCompleted])
  @@map("student_profiles")
}

model StudentEducation {
  id                      String             @id @default(uuid()) @db.Char(36)
  studentProfileId        String             @unique @map("student_profile_id") @db.Char(36)
  degreeLevel             StudentDegreeLevel @map("degree_level")
  university              String             @db.VarChar(255)
  department              String             @db.VarChar(255)
  majorSubject            String             @map("major_subject") @db.VarChar(255)
  faculty                 String?            @db.VarChar(255)
  currentYear             String?            @map("current_year") @db.VarChar(50)
  expectedGraduationYear  Int                @map("expected_graduation_year")
  cgpa                    Decimal?           @db.Decimal(4, 2)
  gradingScale            String?            @map("grading_scale") @db.VarChar(50)
  thesisTitle             String?            @map("thesis_title") @db.VarChar(500)
  supervisorName          String?            @map("supervisor_name") @db.VarChar(255)
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@map("student_educations")
}

model StudentResearchInterest {
  id                    String                  @id @default(uuid()) @db.Char(36)
  studentProfileId      String                  @unique @map("student_profile_id") @db.Char(36)
  primaryArea           String                  @map("primary_area") @db.VarChar(255)
  secondaryAreas        Json?                   @map("secondary_areas")
  keywords              Json? 
  preferredTopics       Json?                   @map("preferred_topics")
  interestedDegree      StudentInterestedDegree @map("interested_degree")
  preferredCountries    Json                    @map("preferred_countries")
  preferredUniversities Json?                   @map("preferred_universities")
  preferredIntake       String?                 @map("preferred_intake") @db.VarChar(100)
  fundingNeed           FundingNeed             @map("funding_need")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@map("student_research_interests")
}

model StudentSkill {
  id               String        @id @default(uuid()) @db.Char(36)
  studentProfileId String        @map("student_profile_id") @db.Char(36)
  category         SkillCategory
  name             String        @db.VarChar(120)
  level            String?       @db.VarChar(50)
  createdAt        DateTime      @default(now()) @map("created_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId, category])
  @@map("student_skills")
}

model StudentExperience {
  id               String         @id @default(uuid()) @db.Char(36)
  studentProfileId String         @map("student_profile_id") @db.Char(36)
  type             ExperienceType
  title            String         @db.VarChar(255)
  organization     String?        @db.VarChar(255)
  startDate        DateTime?      @map("start_date") @db.Date
  endDate          DateTime?      @map("end_date") @db.Date
  description      String?        @db.Text
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId, type])
  @@map("student_experiences")
}

model StudentProject {
  id               String   @id @default(uuid()) @db.Char(36)
  studentProfileId String   @map("student_profile_id") @db.Char(36)
  title            String   @db.VarChar(255)
  description      String?  @db.Text
  technologies     Json?
  link             String?  @db.VarChar(500)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId])
  @@map("student_projects")
}

model StudentPublication {
  id                  String   @id @default(uuid()) @db.Char(36)
  studentProfileId    String   @map("student_profile_id") @db.Char(36)
  title               String   @db.VarChar(500)
  journalOrConference String?  @map("journal_or_conference") @db.VarChar(255)
  year                Int?
  doi                 String?  @db.VarChar(255)
  url                 String?  @db.VarChar(500)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId])
  @@map("student_publications")
}

model StudentDocument {
  id               String                @id @default(uuid()) @db.Char(36)
  studentProfileId String                @map("student_profile_id") @db.Char(36)
  type             StudentDocumentType
  fileKey          String                @map("file_key") @db.VarChar(1000)
  originalName     String                @map("original_name") @db.VarChar(500)
  mimeType         String                @map("mime_type") @db.VarChar(100)
  sizeBytes        Int                   @map("size_bytes")
  status           StudentDocumentStatus @default(uploaded)
  uploadedAt       DateTime              @default(now()) @map("uploaded_at")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId, type])
  @@map("student_documents")
}

model StudentTestScore {
  id               String          @id @default(uuid()) @db.Char(36)
  studentProfileId String          @map("student_profile_id") @db.Char(36)
  testType         EnglishTestType @map("test_type")
  score            Decimal?        @db.Decimal(5, 2)
  testDate         DateTime?       @map("test_date") @db.Date
  expiryDate       DateTime?       @map("expiry_date") @db.Date
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId, testType])
  @@map("student_test_scores")
}

model StudentPreference {
  id                          String                  @id @default(uuid()) @db.Char(36)
  studentProfileId            String                  @unique @map("student_profile_id") @db.Char(36)
  preferredEmailTone          PreferredEmailTone?     @map("preferred_email_tone")
  emailSignature              String?                 @map("email_signature") @db.Text
  defaultSendingEmailAccountId String?                @map("default_sending_email_account_id") @db.Char(36)
  targetDegree                StudentInterestedDegree? @map("target_degree")
  targetCountries             Json?                   @map("target_countries")
  targetIntake                String?                 @map("target_intake") @db.VarChar(100)
  budgetRange                 String?                 @map("budget_range") @db.VarChar(100)
  englishTest                 EnglishTestType?        @map("english_test")
  englishScore                Decimal?                @map("english_score") @db.Decimal(5, 2)
  greScore                    Decimal?                @map("gre_score") @db.Decimal(6, 2)
  gmatScore                   Decimal?                @map("gmat_score") @db.Decimal(6, 2)
  publicationCount            Int?                    @map("publication_count")
  createdAt                   DateTime                @default(now()) @map("created_at")
  updatedAt                   DateTime                @updatedAt @map("updated_at")

  studentProfile      StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  defaultSendingEmail EmailAccount?  @relation(fields: [defaultSendingEmailAccountId], references: [id])

  @@index([defaultSendingEmailAccountId])
  @@map("student_preferences")
}

model OauthAccount {
  id                     String        @id @default(uuid()) @db.Char(36)
  userId                 String        @map("user_id") @db.Char(36)
  provider               OAuthProvider
  providerAccountId      String        @map("provider_account_id") @db.VarChar(255)
  email                  String        @db.VarChar(255)
  accessToken            String?       @map("access_token") @db.Text
  refreshToken           String?       @map("refresh_token") @db.Text
  tokenExpiresAt         DateTime?     @map("token_expires_at")
  scopes                 Json?
  isEmailSendingEnabled  Boolean       @default(false) @map("is_email_sending_enabled")
  isInboxSyncEnabled     Boolean       @default(false) @map("is_inbox_sync_enabled")
  lastSyncedAt           DateTime?     @map("last_synced_at")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailThreads EmailThread[]

  @@unique([userId, provider, providerAccountId])
  @@index([userId, provider])
  @@map("oauth_accounts")
}

model SmtpAccount {
  id             String         @id @default(uuid()) @db.Char(36)
  userId         String         @map("user_id") @db.Char(36)
  name           String         @db.VarChar(100)
  fromEmail      String         @map("from_email") @db.VarChar(255)
  fromName       String?        @map("from_name") @db.VarChar(255)
  host           String         @db.VarChar(255)
  port           Int
  encryption     SmtpEncryption @default(tls)
  username       String         @db.VarChar(255)
  password       String         @db.VarChar(500)
  imapHost       String?        @map("imap_host") @db.VarChar(255)
  imapPort       Int?           @map("imap_port")
  imapEncryption SmtpEncryption? @map("imap_encryption")
  imapUsername   String?        @map("imap_username") @db.VarChar(255)
  imapPassword   String?        @map("imap_password") @db.VarChar(500)
  isVerified     Boolean        @default(false) @map("is_verified")
  verifiedAt     DateTime?      @map("verified_at")
  isDefault      Boolean        @default(false) @map("is_default")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailThreads EmailThread[]

  @@index([userId])
  @@map("smtp_accounts")
}

model EmailAccount {
  id                    String               @id @default(uuid()) @db.Char(36)
  userId                String               @map("user_id") @db.Char(36)
  type                  EmailAccountType
  provider              EmailAccountProvider @default(CUSTOM)
  label                 String?              @db.VarChar(120)
  email                 String               @db.VarChar(255)
  smtpHost              String               @map("smtp_host") @db.VarChar(255)
  smtpPort              Int                  @map("smtp_port")
  smtpSecure            Boolean              @default(true) @map("smtp_secure")
  smtpUsername          String               @map("smtp_username") @db.VarChar(500)
  encryptedSmtpPassword String               @map("encrypted_smtp_password") @db.VarChar(1000)
  imapHost              String?              @map("imap_host") @db.VarChar(255)
  imapPort              Int?                 @map("imap_port")
  imapSecure            Boolean              @default(true) @map("imap_secure")
  imapUsername          String?              @map("imap_username") @db.VarChar(500)
  encryptedImapPassword String?              @map("encrypted_imap_password") @db.VarChar(1000)
  isSystemManaged       Boolean              @default(false) @map("is_system_managed")
  isEditable            Boolean              @default(true) @map("is_editable")
  mailboxStatus         MailboxStatus        @default(pending) @map("mailbox_status")
  isDefault             Boolean              @default(false) @map("is_default")
  isActive              Boolean              @default(false) @map("is_active")
  lastSyncAt            DateTime?            @map("last_sync_at")
  lastTestedAt          DateTime?            @map("last_tested_at")
  lastTestStatus        String?              @map("last_test_status") @db.VarChar(50)
  lastTestError         String?              @map("last_test_error") @db.VarChar(1000)
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncLogs  MailboxSyncLog[]
  studentPreferences StudentPreference[]

  @@unique([userId, email])
  @@index([userId, type, isActive])
  @@index([email])
  @@map("email_accounts")
}

model MailSettings {
  id                       String   @id @default("default") @db.VarChar(50)
  systemMailDomain         String   @default("researvia.com") @map("system_mail_domain") @db.VarChar(255)
  systemSmtpHost           String   @default("mail.researvia.com") @map("system_smtp_host") @db.VarChar(255)
  systemSmtpPort           Int      @default(465) @map("system_smtp_port")
  systemImapHost           String   @default("mail.researvia.com") @map("system_imap_host") @db.VarChar(255)
  systemImapPort           Int      @default(993) @map("system_imap_port")
  systemMailboxQuotaMb     Int      @default(1024) @map("system_mailbox_quota_mb")
  trackingBaseUrl          String   @default("http://localhost:3001") @map("tracking_base_url") @db.VarChar(500)
  mailboxProvisionRequired Boolean  @default(false) @map("mailbox_provision_required")
  cpanelBaseUrl            String?  @map("cpanel_base_url") @db.VarChar(500)
  cpanelUsername           String?  @map("cpanel_username") @db.VarChar(255)
  encryptedCpanelApiToken  String?  @map("encrypted_cpanel_api_token") @db.VarChar(1000)
  emailQueuesEnabled       Boolean  @default(false) @map("email_queues_enabled")
  emailSendAsync           Boolean  @default(false) @map("email_send_async")
  emailSendConcurrency     Int      @default(5) @map("email_send_concurrency")
  mailboxSyncConcurrency   Int      @default(3) @map("mailbox_sync_concurrency")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("mail_settings")
}

model Country {
  id                   String   @id @default(uuid()) @db.Char(36)
  name                 String   @db.VarChar(100)
  isoAlpha2            String   @unique @map("iso_alpha2") @db.Char(2)
  isoAlpha3            String   @unique @map("iso_alpha3") @db.Char(3)
  region               String?  @db.VarChar(100)
  subregion            String?  @db.VarChar(100)
  flagEmoji            String?  @map("flag_emoji") @db.VarChar(10)
  isPopularDestination Boolean  @default(false) @map("is_popular_destination")
  createdAt            DateTime @default(now()) @map("created_at")

  universities University[]
  scholarships Scholarship[]

  @@map("countries")
}

model University {
  id              String           @id @default(uuid()) @db.Char(36)
  rorId           String?          @unique @map("ror_id") @db.VarChar(50)
  name            String           @db.VarChar(500)
  nameAliases     Json?            @map("name_aliases")
