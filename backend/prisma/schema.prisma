// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid()) @db.Char(36)
  email                String    @unique @db.VarChar(255)
  passwordHash         String?   @map("password_hash") @db.VarChar(255)
  fullName             String    @map("full_name") @db.VarChar(255)
  avatarUrl            String?   @map("avatar_url") @db.VarChar(500)
  role                 UserRole  @default(user)
  status               UserStatus @default(active)
  emailVerifiedAt      DateTime? @map("email_verified_at")
  twoFactorSecret      String?   @map("two_factor_secret") @db.VarChar(255)
  twoFactorEnabled     Boolean   @default(false) @map("two_factor_enabled")
  twoFactorBackupCodes Json?     @map("two_factor_backup_codes")
  lastLoginAt          DateTime? @map("last_login_at")
  lastLoginIp          String?   @map("last_login_ip") @db.VarChar(45)
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime? @map("locked_until")
  tokenVersion         Int       @default(0) @map("token_version")
  passwordChangedAt    DateTime? @map("password_changed_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  profile           UserProfile?
  studentProfile    StudentProfile?
  academicProfile   StudentAcademicProfile?
  oauthAccounts     OauthAccount[]
  smtpAccounts      SmtpAccount[]
  emailAccounts     EmailAccount[]
  subscriptions     Subscription[]
  credits           Credits?
  creditTransactions CreditTransaction[]
  emailThreads      EmailThread[]
  emailMessages     EmailMessage[]
  followupSequences FollowupSequence[]
  applications      Application[]
  favorites         Favorite[]
  savedScholarships SavedScholarship[]
  notifications     Notification[]
  activityLogs      ActivityLog[]
  imports           Import[]
  emailRevealLogs   EmailRevealLog[]
  matchScores       MatchScore[]
  cvParseLogs       CvParseLog[]
  usageMetrics      UsageMetric[]
  invoices          BillingInvoice[]
  paymentTransactions PaymentTransaction[]
  subscriptionsOwned Team[] @relation("TeamOwner")
  teamMemberships   TeamMember[]
  couponRedemptions CouponRedemption[]
  scholarshipUnlocks ScholarshipUnlock[]
  opportunityUnlocks OpportunityUnlock[]
  sessions          ActiveSession[]

  @@index([status, deletedAt])
  @@map("users")
}

model UserProfile {
  id                String       @id @default(uuid()) @db.Char(36)
  userId            String       @unique @map("user_id") @db.Char(36)
  bio               String?      @db.Text
  currentDegree     DegreeLevel? @map("current_degree")
  gpa               Decimal?     @db.Decimal(4, 2)
  ieltsScore        Decimal?     @map("ielts_score") @db.Decimal(3, 1)
  toeflScore        Int?         @map("toefl_score")
  greVerbal         Int?         @map("gre_verbal")
  greQuant          Int?         @map("gre_quant")
  greAwa            Decimal?     @map("gre_awa") @db.Decimal(3, 1)
  researchInterests Json?        @map("research_interests")
  targetDegree      TargetDegree? @map("target_degree")
  targetCountries   Json?        @map("target_countries")
  targetStartTerm   String?      @map("target_start_term") @db.VarChar(20)
  linkedinUrl       String?      @map("linkedin_url") @db.VarChar(500)
  githubUrl         String?      @map("github_url") @db.VarChar(500)
  googleScholarUrl  String?      @map("google_scholar_url") @db.VarChar(500)
  orcidId           String?      @map("orcid_id") @db.VarChar(50)
  cvFileKey         String?      @map("cv_file_key") @db.VarChar(500)
  sopFileKey        String?      @map("sop_file_key") @db.VarChar(500)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model StudentProfile {
  id                    String                   @id @default(uuid()) @db.Char(36)
  userId                String                   @unique @map("user_id") @db.Char(36)
  fullName              String                   @map("full_name") @db.VarChar(255)
  preferredName         String?                  @map("preferred_name") @db.VarChar(255)
  profilePhotoUrl       String?                  @map("profile_photo_url") @db.VarChar(500)
  gender                String?                  @db.VarChar(50)
  dateOfBirth           DateTime?                @map("date_of_birth") @db.Date
  nationality           String                   @db.VarChar(100)
  currentCountry        String                   @map("current_country") @db.VarChar(100)
  city                  String?                  @db.VarChar(120)
  phone                 String?                  @db.VarChar(50)
  whatsapp              String?                  @db.VarChar(50)
  linkedin              String?                  @db.VarChar(500)
  github                String?                  @db.VarChar(500)
  website               String?                  @db.VarChar(500)
  shortBio              String?                  @map("short_bio") @db.Text
  careerGoal            String?                  @map("career_goal") @db.Text
  whyInterestedInResearch String?                @map("why_interested_in_research") @db.Text
  profileCompleteness   Int                      @default(0) @map("profile_completeness")
  onboardingCompleted   Boolean                  @default(false) @map("onboarding_completed")
  onboardingStep        Int                      @default(1) @map("onboarding_step")
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")

  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  educations        StudentEducation[]
  researchInterest  StudentResearchInterest?
  skills            StudentSkill[]
  experiences       StudentExperience[]
  projects          StudentProject[]
  publications      StudentPublication[]
  documents         StudentDocument[]
  testScores        StudentTestScore[]
  preference        StudentPreference?

  @@index([nationality])
  @@index([currentCountry])
  @@index([onboardingCompleted])
  @@map("student_profiles")
}

model StudentAcademicProfile {
  id                        String          @id @default(uuid()) @db.Char(36)
  userId                    String          @unique @map("user_id") @db.Char(36)
  currentDegreeLevel        StudentDegreeLevel? @map("current_degree_level")
  currentUniversity         String?         @map("current_university") @db.VarChar(255)
  currentDepartment         String?         @map("current_department") @db.VarChar(255)
  targetDegree              StudentInterestedDegree? @map("target_degree")
  targetIntake              String?         @map("target_intake") @db.VarChar(100)
  gpa                       Decimal?        @db.Decimal(4, 2)
  gradingScale              String?         @map("grading_scale") @db.VarChar(50)
  researchSummary           String?         @map("research_summary") @db.Text
  cvText                    String?         @map("cv_text") @db.LongText
  publicationsCount         Int             @default(0) @map("publications_count")
  researchExperienceYears   Decimal?        @map("research_experience_years") @db.Decimal(4, 1)
  preferredCountriesJson    Json?           @map("preferred_countries_json")
  preferredUniversitiesJson Json?           @map("preferred_universities_json")
  preferredFundingTypesJson Json?           @map("preferred_funding_types_json")
  preferredResearchAreasJson Json?          @map("preferred_research_areas_json")
  lastParsedAt              DateTime?       @map("last_parsed_at")
  lastConfirmedAt           DateTime?       @map("last_confirmed_at")
  parseStatus               CvParseStatus   @default(pending) @map("parse_status")
  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([targetDegree])
  @@index([updatedAt])
  @@map("student_academic_profiles")
}

model StudentEducation {
  id                      String             @id @default(uuid()) @db.Char(36)
  studentProfileId        String             @map("student_profile_id") @db.Char(36)
  isCurrent               Boolean            @default(false) @map("is_current")
  sortOrder               Int                @default(0) @map("sort_order")
  degreeLevel             StudentDegreeLevel @map("degree_level")
  university              String             @db.VarChar(255)
  department              String             @db.VarChar(255)
  majorSubject            String             @map("major_subject") @db.VarChar(255)
  faculty                 String?            @db.VarChar(255)
  currentYear             String?            @map("current_year") @db.VarChar(50)
  expectedGraduationYear  Int                @map("expected_graduation_year")
  cgpa                    Decimal?           @db.Decimal(4, 2)
  gradingScale            String?            @map("grading_scale") @db.VarChar(50)
  thesisTitle             String?            @map("thesis_title") @db.VarChar(500)
  supervisorName          String?            @map("supervisor_name") @db.VarChar(255)
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId, isCurrent])
  @@index([studentProfileId, sortOrder])
  @@map("student_educations")
}

model StudentResearchInterest {
  id                    String                  @id @default(uuid()) @db.Char(36)
  studentProfileId      String                  @unique @map("student_profile_id") @db.Char(36)
  primaryArea           String                  @map("primary_area") @db.VarChar(255)
  secondaryAreas        Json?                   @map("secondary_areas")
  keywords              Json? 
  preferredTopics       Json?                   @map("preferred_topics")
  interestedDegree      StudentInterestedDegree @map("interested_degree")
  preferredCountries    Json                    @map("preferred_countries")
  preferredUniversities Json?                   @map("preferred_universities")
  preferredIntake       String?                 @map("preferred_intake") @db.VarChar(100)
  fundingNeed           Json                    @map("funding_need")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@map("student_research_interests")
}

model StudentSkill {
  id               String        @id @default(uuid()) @db.Char(36)
  studentProfileId String        @map("student_profile_id") @db.Char(36)
  category         SkillCategory
  name             String        @db.VarChar(120)
  level            String?       @db.VarChar(50)
  createdAt        DateTime      @default(now()) @map("created_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId, category])
  @@map("student_skills")
}

model StudentExperience {
  id               String         @id @default(uuid()) @db.Char(36)
  studentProfileId String         @map("student_profile_id") @db.Char(36)
  type             ExperienceType
  title            String         @db.VarChar(255)
  organization     String?        @db.VarChar(255)
  startDate        DateTime?      @map("start_date") @db.Date
  endDate          DateTime?      @map("end_date") @db.Date
  description      String?        @db.Text
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId, type])
  @@map("student_experiences")
}

model StudentProject {
  id               String   @id @default(uuid()) @db.Char(36)
  studentProfileId String   @map("student_profile_id") @db.Char(36)
  title            String   @db.VarChar(255)
  description      String?  @db.Text
  technologies     Json?
  link             String?  @db.VarChar(500)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId])
  @@map("student_projects")
}

model StudentPublication {
  id                  String   @id @default(uuid()) @db.Char(36)
  studentProfileId    String   @map("student_profile_id") @db.Char(36)
  title               String   @db.VarChar(500)
  journalOrConference String?  @map("journal_or_conference") @db.VarChar(255)
  year                Int?
  doi                 String?  @db.VarChar(255)
  url                 String?  @db.VarChar(500)
  publishedAt         DateTime? @map("published_at") @db.Date
  description         String?  @db.Text
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId])
  @@map("student_publications")
}

model StudentDocument {
  id               String                @id @default(uuid()) @db.Char(36)
  studentProfileId String                @map("student_profile_id") @db.Char(36)
  type             StudentDocumentType
  fileKey          String                @map("file_key") @db.VarChar(1000)
  originalName     String                @map("original_name") @db.VarChar(500)
  mimeType         String                @map("mime_type") @db.VarChar(100)
  sizeBytes        Int                   @map("size_bytes")
  status           StudentDocumentStatus @default(uploaded)
  uploadedAt       DateTime              @default(now()) @map("uploaded_at")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId, type])
  @@map("student_documents")
}

model StudentTestScore {
  id               String          @id @default(uuid()) @db.Char(36)
  studentProfileId String          @map("student_profile_id") @db.Char(36)
  testType         EnglishTestType @map("test_type")
  score            Decimal?        @db.Decimal(5, 2)
  testDate         DateTime?       @map("test_date") @db.Date
  expiryDate       DateTime?       @map("expiry_date") @db.Date
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId, testType])
  @@map("student_test_scores")
}

model StudentPreference {
  id                          String                  @id @default(uuid()) @db.Char(36)
  studentProfileId            String                  @unique @map("student_profile_id") @db.Char(36)
  preferredEmailTone          PreferredEmailTone?     @map("preferred_email_tone")
  emailSignature              String?                 @map("email_signature") @db.Text
  defaultSendingEmailAccountId String?                @map("default_sending_email_account_id") @db.Char(36)
  targetDegree                StudentInterestedDegree? @map("target_degree")
  targetCountries             Json?                   @map("target_countries")
  targetIntake                String?                 @map("target_intake") @db.VarChar(100)
  budgetRange                 String?                 @map("budget_range") @db.VarChar(100)
  englishTest                 EnglishTestType?        @map("english_test")
  englishScore                Decimal?                @map("english_score") @db.Decimal(5, 2)
  greScore                    Decimal?                @map("gre_score") @db.Decimal(6, 2)
  gmatScore                   Decimal?                @map("gmat_score") @db.Decimal(6, 2)
  publicationCount            Int?                    @map("publication_count")
  createdAt                   DateTime                @default(now()) @map("created_at")
  updatedAt                   DateTime                @updatedAt @map("updated_at")

  studentProfile      StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  defaultSendingEmail EmailAccount?  @relation(fields: [defaultSendingEmailAccountId], references: [id])

  @@index([defaultSendingEmailAccountId])
  @@map("student_preferences")
}

model OauthAccount {
  id                     String        @id @default(uuid()) @db.Char(36)
  userId                 String        @map("user_id") @db.Char(36)
  provider               OAuthProvider
  providerAccountId      String        @map("provider_account_id") @db.VarChar(255)
  email                  String        @db.VarChar(255)
  accessToken            String?       @map("access_token") @db.Text
  refreshToken           String?       @map("refresh_token") @db.Text
  tokenExpiresAt         DateTime?     @map("token_expires_at")
  scopes                 Json?
  isEmailSendingEnabled  Boolean       @default(false) @map("is_email_sending_enabled")
  isInboxSyncEnabled     Boolean       @default(false) @map("is_inbox_sync_enabled")
  lastSyncedAt           DateTime?     @map("last_synced_at")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailThreads EmailThread[]

  @@unique([userId, provider, providerAccountId])
  @@index([userId, provider])
  @@map("oauth_accounts")
}

model SmtpAccount {
  id             String         @id @default(uuid()) @db.Char(36)
  userId         String         @map("user_id") @db.Char(36)
  name           String         @db.VarChar(100)
  fromEmail      String         @map("from_email") @db.VarChar(255)
