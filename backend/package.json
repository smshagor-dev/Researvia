{
  "name": "researvia-backend",
  "version": "1.0.0",
  "description": "ResearVia backend API",
  "private": true,
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && nest build",
    "start": "npm run db:prepare && node dist/main.js",
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "start:dev": "npm run dev",
    "start:debug": "nest start --debug --watch",
    "start:worker": "node dist/workers/index.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:prepare": "prisma migrate deploy",
    "db:prepare:dev": "npm run prisma:generate && npm run db:prepare && prisma db seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "import:universities:openalex": "ts-node prisma/import-openalex-universities.ts",
    "import:professors:openalex": "ts-node prisma/import-openalex-professors.ts",
    "backfill:student-access": "ts-node prisma/backfill-student-access.ts",
    "redis:ensure": "powershell -ExecutionPolicy Bypass -File scripts/ensure-redis.ps1",
    "load:test:100": "node scripts/load-test.mjs 100",
    "load:test:1000": "node scripts/load-test.mjs 1000"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/websockets": "^11.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@prisma/client": "^5.16.1",
    "@sentry/node": "^10.57.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.0",
    "bullmq": "^5.12.0",
    "cache-manager": "^6.4.3",
    "cache-manager-redis-yet": "^5.1.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dayjs": "^1.11.12",
    "googleapis": "^140.0.1",
    "helmet": "^7.1.0",
    "imap-simple": "^5.1.0",
    "ioredis": "^5.4.1",
    "isomorphic-fetch": "^3.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.7.1",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "nvm": "^0.0.4",
    "openai": "^4.52.7",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-microsoft": "^1.0.0",
    "pino": "^9.3.1",
    "pino-http": "^10.2.0",
    "prisma": "^5.16.1",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "stripe": "^16.2.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.26",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.15",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "compression": "^1.8.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
