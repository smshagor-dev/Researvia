# ResearVia backend bootstrap environment
# Copy to backend/.env for local development.
# Important:
# - This file should contain only bootstrap infra/secrets required before the app can read DB settings.
# - Business/runtime settings should be managed from the admin panel and stored in the database.
# - If a value below is later moved to DB-backed admin settings, keep only the minimum boot value here.

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001

# Public URLs are bootstrap values. After admin settings are available, runtime-facing
# URLs should be managed from DB/admin where possible.
APP_URL=http://localhost:3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# MySQL example:
DATABASE_URL=mysql://researvia:researvia_pass@localhost:3306/researvia_db?connection_limit=10

# -----------------------------------------------------------------------------
# Auth / security
# -----------------------------------------------------------------------------
# Use long random secrets in production.
# These must stay outside DB because they are needed to trust the DB-loaded config.
JWT_SECRET=change-me-to-a-random-32-plus-character-secret
JWT_REFRESH_SECRET=change-me-to-a-different-random-32-plus-character-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Used to decrypt DB-stored secrets, so this must remain bootstrap-only.
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# -----------------------------------------------------------------------------
# Redis / queues
# -----------------------------------------------------------------------------
# Redis connection is bootstrap infra, not admin-managed.
REDIS_URL=redis://localhost:6379

# Optional discrete Redis settings when REDIS_URL is not used:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Billing: Stripe
# Master API/webhook secrets stay in env or secret manager.
# Product/plan mapping should eventually be editable from admin/DB.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs should match your seeded plan slugs and billing intervals.
STRIPE_PRICE_ID_STARTER_MONTHLY=
STRIPE_PRICE_ID_STARTER_YEARLY=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=
STRIPE_PRICE_ID_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ID_ENTERPRISE_YEARLY=

# -----------------------------------------------------------------------------
# Billing: NOWPayments
# Master secrets stay in env or secret manager.
# UX-facing URLs/currencies should ideally be admin-managed from DB.
# -----------------------------------------------------------------------------
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_SUPPORTED_CURRENCIES=btc,eth,usdttrc20
NOWPAYMENTS_SUCCESS_URL=
NOWPAYMENTS_CANCEL_URL=
NOWPAYMENTS_IPN_CALLBACK_URL=

# -----------------------------------------------------------------------------
# Google / Gmail OAuth
# -----------------------------------------------------------------------------
# Master OAuth app secrets stay in env or secret manager.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Microsoft / Outlook OAuth
# -----------------------------------------------------------------------------
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# -----------------------------------------------------------------------------
# SMTP fallback / system mail
# Mail routing and operational mail settings should be managed from admin/DB.
# -----------------------------------------------------------------------------
SYSTEM_EMAIL_FROM=noreply@researvia.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALLOW_EMAIL_FALLBACK=false

# -----------------------------------------------------------------------------
# Storage: local, S3, or Cloudflare R2
# Credentials remain bootstrap-only. Bucket policy/display settings can be DB-managed separately.
# -----------------------------------------------------------------------------
STORAGE_DRIVER=local
S3_ENDPOINT=
S3_BUCKET=researvia
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# Observability: Sentry + OpenTelemetry
# DSNs/tokens remain secret-managed. Sampling and feature toggles can move to admin/DB later.
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

OTEL_ENABLED=false
OTEL_SERVICE_NAME=researvia-backend

# -----------------------------------------------------------------------------
# AI providers
# Provider master keys remain secret-managed. Provider selection/model strategy can be DB-managed.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Discovery sources
# Base URLs are currently bootstrap values. In the target architecture these should move to DB/admin settings.
# -----------------------------------------------------------------------------
OPENALEX_BASE_URL=https://api.openalex.org
OPENALEX_EMAIL=ops@researvia.com
ORCID_BASE_URL=https://pub.orcid.org/v3.0
CROSSREF_BASE_URL=https://api.crossref.org
ROR_BASE_URL=https://api.ror.org

# -----------------------------------------------------------------------------
# Scholarship / opportunity source adapters
# These are better as admin-managed DB settings when source control must change without redeploy.
# -----------------------------------------------------------------------------
DAAD_API_URL=
ERASMUS_API_URL=
FULBRIGHT_API_URL=
CHEVENING_API_URL=
MEXT_API_URL=
COMMONWEALTH_API_URL=
UNIVERSITY_SCHOLARSHIP_API_URL=

# -----------------------------------------------------------------------------
# App limits / uploads
# Feature/runtime limits should prefer DB-backed admin settings where feasible.
# -----------------------------------------------------------------------------
STUDENT_DOCUMENT_MAX_BYTES=10485760
PRISMA_QUERY_LOGGING=false

# -----------------------------------------------------------------------------
# Cron schedules
# Crons are currently boot-time values.
# If you want "all setup from admin", these schedules should be moved to DB-backed system settings next.
# -----------------------------------------------------------------------------
DISCOVERY_DAILY_CRON=0 2 * * *
PROFILE_SYNC_DAILY_CRON=0 3 * * *
PUBLICATION_SYNC_DAILY_CRON=0 4 * * *
QUALITY_SCORE_DAILY_CRON=0 5 * * *
DEDUP_WEEKLY_CRON=0 3 * * 0
AI_MATCH_REFRESH_DAILY_CRON=30 2 * * *

SCHOLARSHIP_DISCOVERY_CRON=0 1 * * *
SCHOLARSHIP_SYNC_CRON=0 2 * * *
SCHOLARSHIP_DEADLINE_CRON=0 3 * * *
SCHOLARSHIP_QUALITY_CRON=0 4 * * *

OPPORTUNITY_DISCOVERY_CRON=0 */12 * * *
OPPORTUNITY_SYNC_CRON=10 */12 * * *
OPPORTUNITY_QUALITY_CRON=20 */12 * * *

BILLING_SYNC_CRON=0 2 * * *
INVOICE_SYNC_CRON=0 3 * * *
USAGE_RESET_CRON=0 0 1 * *

BACKUP_DATABASE_CRON=0 1 * * *
BACKUP_STORAGE_CRON=0 2 * * 0
BACKUP_FULL_SNAPSHOT_CRON=0 3 1 * *

# -----------------------------------------------------------------------------
# Workers / queue health
# Infrastructure safety knobs are usually bootstrap-level, not admin-managed.
# -----------------------------------------------------------------------------
WORKER_HEARTBEAT_INTERVAL_MS=30000
WORKER_OFFLINE_THRESHOLD_MS=60000
QUEUE_STUCK_JOB_THRESHOLD_MS=900000
WORKER_VERSION=1.0.0
